{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "enixCode - direction artistique. Palette Ardoise Froide. Voir PALETTE.md pour les rôles sémantiques.",
  "color": {
    "light": {
      "paper":     { "$type": "color", "$value": "#f8f9fa" },
      "paper-2":   { "$type": "color", "$value": "#edeef0" },
      "paper-3":   { "$type": "color", "$value": "#e1e3e6" },
      "ink":       { "$type": "color", "$value": "#111318" },
      "ink-soft":  { "$type": "color", "$value": "#34373d" },
      "muted":     { "$type": "color", "$value": "#6b7280" },
      "rule":      { "$type": "color", "$value": "#111318" },
      "rule-soft": { "$type": "color", "$value": "#c8cbd0" },
      "hot":       { "$type": "color", "$value": "#2563eb" },
      "blue":      { "$type": "color", "$value": "#2563eb" },
      "yellow":    { "$type": "color", "$value": "#60a5fa" },
      "mark-bg":   { "$type": "color", "$value": "#111318" },
      "mark-fg":   { "$type": "color", "$value": "#f8f9fa" }
    },
    "dark": {
      "paper":     { "$type": "color", "$value": "#0d0e12" },
      "paper-2":   { "$type": "color", "$value": "#13141a" },
      "paper-3":   { "$type": "color", "$value": "#1a1c24" },
      "ink":       { "$type": "color", "$value": "#e8eaf0" },
      "ink-soft":  { "$type": "color", "$value": "#b8bac2" },
      "muted":     { "$type": "color", "$value": "#7d8390" },
      "rule":      { "$type": "color", "$value": "#e8eaf0" },
      "rule-soft": { "$type": "color", "$value": "#2a2d35" },
      "hot":       { "$type": "color", "$value": "#60a5fa" },
      "blue":      { "$type": "color", "$value": "#60a5fa" },
      "yellow":    { "$type": "color", "$value": "#93c5fd" },
      "mark-bg":   { "$type": "color", "$value": "#1a1c24" },
      "mark-fg":   { "$type": "color", "$value": "#e8eaf0" }
    },
    "constants": {
      "constant-ink":   { "$type": "color", "$value": "#111318" },
      "constant-paper": { "$type": "color", "$value": "#f8f9fa" }
    }
  },
  "typography": {
    "family": {
      "display": { "$type": "fontFamily", "$value": ["Archivo Narrow", "system-ui", "sans-serif"] },
      "body":    { "$type": "fontFamily", "$value": ["Archivo", "system-ui", "sans-serif"] },
      "accent":  { "$type": "fontFamily", "$value": ["Fraunces", "serif"] },
      "mono":    { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"] }
    },
    "weight": {
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "bold":     { "$type": "fontWeight", "$value": 700 },
      "black":    { "$type": "fontWeight", "$value": 900 }
    }
  }
}
